{
  "name": "tauri-app",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "electron:dev": "node electron/dev.mjs",
    "electron:build": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.termo.app",
    "productName": "Termo",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/dev.mjs"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "src-tauri/icons/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}_${version}_x64-electron-setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "chenyang19940919",
      "repo": "termo"
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.24.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.12.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
